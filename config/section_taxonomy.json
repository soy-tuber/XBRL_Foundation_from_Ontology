        "ManagementAnalysisOfFinancialPositionOperatingResultsAndCashFlowsTextBlock",
        "BusinessResultsOfGroupTextBlock",
        "AnalysisOfFinancialPositionOperatingResultsAndCashFlowsTextBlock"
      ],
      "order": 30
    },
    {
      "section_code": "management_policy",
