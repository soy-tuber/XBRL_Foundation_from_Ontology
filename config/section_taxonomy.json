      "patterns": ["BusinessRisksTextBlock", "BusinessRisksHeading"],
      "order": 20
    },
    {
      "section_code": "mdna",
      "section_name_ja": "経営者による財政状態、経営成績及びキャッシュ・フローの状況の分析",
