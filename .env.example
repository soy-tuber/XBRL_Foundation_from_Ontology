# ----- EDINET -----
EDINET_API_KEY=your_edinet_api_key
EDINET_DRIVE_PATH=/abs/path/to/edinet_store

# ----- DB -----
DB_PATH=data/xbrl_financial.db

# ----- LLM (いずれか) -----
# (A) Gemini API (課金)
LLM_BACKEND=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro

# (B) Gemini CLI (OAuth 無料枠 60/min, 1000/day) ← 課金避けたい時
# 事前準備: npm install -g @google/gemini-cli && gemini   (初回OAuth)
# LLM_BACKEND=gemini_cli
# GEMINI_CLI_MODEL=gemini-2.5-pro
# GEMINI_CLI_PATH=gemini               # PATH で見つからない場合はフルパス
# GEMINI_API_KEY=...                    # 埋め込み専用。無ければ LOCAL_LLM_ENDPOINT へフォールバック

# (C) ローカル OpenAI 互換 (Nemotron など)
# LLM_BACKEND=local
# LOCAL_LLM_ENDPOINT=http://127.0.0.1:8000/v1
# LOCAL_LLM_MODEL=nemotron
# LOCAL_LLM_API_KEY=

# ----- Phase 2: Google Drive (任意) -----
# GDRIVE_SERVICE_ACCOUNT_JSON=/abs/path/to/service_account.json
