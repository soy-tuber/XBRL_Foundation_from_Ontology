# ----- EDINET -----
EDINET_API_KEY=your_edinet_api_key
EDINET_DRIVE_PATH=/abs/path/to/edinet_store

# ----- DB -----
DB_PATH=data/xbrl_financial.db

# ----- LLM (どちらか) -----
LLM_BACKEND=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro

# ローカル (OpenAI 互換) を使うなら:
# LLM_BACKEND=local
# LOCAL_LLM_ENDPOINT=http://127.0.0.1:8000/v1
# LOCAL_LLM_MODEL=nemotron
# LOCAL_LLM_API_KEY=

